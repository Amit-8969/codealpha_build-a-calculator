<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern JS Calculator</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #f0f2f5;
        }

        .calculator {
            background-color: #1e222b;
            padding: 20px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
            width: 320px;
        }

        .display {
            width: 100%;
            height: 80px;
            background-color: #282c34;
            border: none;
            border-radius: 10px;
            margin-bottom: 20px;
            color: #ffffff;
            font-size: 2rem;
            text-align: right;
            padding: 15px;
            pointer-events: none; /* Prevents manual typing */
        }

        .buttons {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        button {
            padding: 20px;
            border-radius: 12px;
            border: none;
            font-size: 1.25rem;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.1s;
            background-color: #3e4451;
            color: #ffffff;
        }

        button:active {
            transform: scale(0.95);
        }

        button.operator {
            background-color: #ff9f0a;
            color: #ffffff;
        }

        button.operator:hover {
            background-color: #cc7f08;
        }

        button.clear {
            background-color: #e06c75;
            color: #ffffff;
        }

        button.clear:hover {
            background-color: #c2535b;
        }

        button.equal {
            background-color: #98c379;
            color: #1e222b;
            grid-column: span 2;
        }

        button.equal:hover {
            background-color: #7cb058;
        }

        button:hover {
            background-color: #4b5263;
        }
    </style>
</head>
<body>

<div class="calculator">
    <input type="text" id="display" class="display" readonly value="0">

    <div class="buttons">
        <button class="clear" onclick="clearDisplay()">C</button>
        <button onclick="appendValue('/')" class="operator">÷</button>
        <button onclick="appendValue('*')" class="operator">×</button>
        <button onclick="deleteLast()">⌫</button>

        <button onclick="appendValue('7')">7</button>
        <button onclick="appendValue('8')">8</button>
        <button onclick="appendValue('9')">9</button>
        <button onclick="appendValue('-')" class="operator">−</button>

        <button onclick="appendValue('4')">4</button>
        <button onclick="appendValue('5')">5</button>
        <button onclick="appendValue('6')">6</button>
        <button onclick="appendValue('+')" class="operator">+</button>

        <button onclick="appendValue('1')">1</button>
        <button onclick="appendValue('2')">2</button>
        <button onclick="appendValue('3')">3</button>
        <button onclick="calculate()" class="equal">=</button>

        <button onclick="appendValue('0')" style="grid-column: span 2;">0</button>
        <button onclick="appendValue('.')">.</button>
    </div>
</div>

<script>
    const display = document.getElementById('display');
    let isResetNecessary = false;

    // Appends numbers or operators to the screen
    function appendValue(value) {
        // Clear screen if a previous calculation was done and a new number is pressed
        if (isResetNecessary && !isNaN(value)) {
            display.value = '';
        }
        isResetNecessary = false;

        if (display.value === '0' && value !== '.') {
            display.value = value;
        } else {
            display.value += value;
        }
    }

    // Completely clears the screen
    function clearDisplay() {
        display.value = '0';
    }

    // Deletes the single last character entered
    function deleteLast() {
        if (display.value.length > 1) {
            display.value = display.value.slice(0, -1);
        } else {
            display.value = '0';
        }
    }

    // Evaluates the string expression mathematically
    function calculate() {
        try {
            // FIXED: Wrapped the return statement inside backticks (template literals) 
            // so JavaScript can properly construct the evaluation function.
            const result = new Function(`return ${display.value}`)();
            
            // Handle edge cases like division by zero resulting in Infinity
            if (result === Infinity || isNaN(result)) {
                display.value = "Error";
            } else {
                // Round to maximum 8 decimal places to prevent float precision artifacts
                display.value = Number(Math.round(result + 'e8') + 'e-8');
            }
            isResetNecessary = true;
        } catch (error) {
            display.value = 'Error';
            isResetNecessary = true;
        }
    }
</script>

</body>
</html>
